version: '1.0'
services:
  termux:
    image: termux/android
    restart: always
    command: ["/storage/emulated/0//start_termux.sh"]
    environment:
      - TERMUX_HOME=/storage/emulated/0/
      - PATH=/data/data/com.termux/files/usr/bin:$/storage/emulated/0/
    volumes:
      - /data/data/com.elparadisogonzalo.vhdx/files/home:/storage/emulated/0/
      - /sdcard/Elparadisogonzalo
    network_mode: "host"
