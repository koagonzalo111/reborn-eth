# Update the PDF to include production builds and rename

pdf_path_updated = '/mnt/data/reborn-dependabot.pdf'
doc = SimpleDocTemplate(pdf_path_updated, pagesize=A4)
story = []

# Title
story.append(Paragraph("Reborn Dependabot Configuration", styles['Title']))
story.append(Spacer(1, 12))

# Intro paragraph
intro_text_updated = """
This configuration defines Dependabot settings to ensure Elparadisogonzalo's project remains secure, 
production-ready, and up to date. It includes allowed workflows, dependencies to allow, partial synchronization, 
and production build workflows for deployment.
"""
story.append(Paragraph(intro_text_updated, styles['Normal']))
story.append(Spacer(1, 12))

# Allowed workflows
story.append(Paragraph("Allowed Workflows", styles['Heading2']))
workflows_updated = [
    "Security updates for npm and GitHub Actions",
    "Automated PR creation for dependency updates",
    "Workflow to run tests and build before merging",
    "Workflow to verify smart contract ABI compatibility",
    "Workflow for IPFS deployment testing",
    "Production build workflow for dApp frontend",
    "Production build workflow for backend API"
]
for wf in workflows_updated:
    story.append(Paragraph(f"• {wf}", styles['Normal']))
story.append(Spacer(1, 12))

# Dependencies to allow
story.append(Paragraph("Dependencies to Allow", styles['Heading2']))
deps_updated = [
    "npm: ethers, web3, xml2js, dotenv",
    "npm: react, react-dom, next.js",
    "npm: @metamask/detect-provider",
    "GitHub Actions: actions/checkout, actions/setup-node",
    "Security patches for critical blockchain libraries",
    "Build tools: webpack, babel, esbuild, vite"
]
for dep in deps_updated:
    story.append(Paragraph(f"• {dep}", styles['Normal']))
story.append(Spacer(1, 12))

# Partial synchronization section
story.append(Paragraph("Partial Synchronization Plan", styles['Heading2']))
partial_sync_text_updated = """
Partial synchronization will begin with monitoring Ethereum mainnet and testnet dependencies only. 
Smart contract-related dependencies will be updated in isolation before expanding to frontend, backend, 
and cloud infrastructure. Production build workflows will be validated in staging before enabling auto-merge.
"""
story.append(Paragraph(partial_sync_text_updated, styles['Normal']))
story.append(Spacer(1, 12))

# Table - example dependabot.yml snippet
story.append(Paragraph("Example dependabot.yml Configuration Snippet", styles['Heading2']))
yaml_snippet_updated = [
    ["version", "2"],
    ["updates", ""],
    ["- package-ecosystem", "npm"],
    ["  directory", "/"],
    ["  schedule", "interval: weekly"],
    ["  allow", "dependency-type: all"],
    ["  ignore", "dependency-type: devDependencies"]
]
table_updated = Table(yaml_snippet_updated, colWidths=[200, 300])
table_updated.setStyle(TableStyle([
    ('BACKGROUND', (0,0), (-1,0), colors.grey),
    ('TEXTCOLOR', (0,0), (-1,0), colors.whitesmoke),
    ('ALIGN', (0,0), (-1,-1), 'LEFT'),
    ('FONTNAME', (0,0), (-1,0), 'Helvetica-Bold'),
    ('BOTTOMPADDING', (0,0), (-1,0), 12),
    ('BACKGROUND', (0,1), (-1,-1), colors.beige),
    ('GRID', (0,0), (-1,-1), 1, colors.black),
]))
story.append(table_updated)

doc.build(story)

pdf_path_updated
